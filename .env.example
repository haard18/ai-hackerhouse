# ──────────────────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env.
# ──────────────────────────────────────────────────────────────

# --- Database (Postgres) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_trading?schema=public"

# --- API server ---
API_PORT=4000

# --- Model providers (Yug) — only set the ones you use ---
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_API_KEY=""

# --- Market data feed (data-feed package) ---
# Provider for live market data. Use "stub" for deterministic fake data.
MARKET_DATA_SOURCE="stub"
MARKET_DATA_API_KEY=""

# --- Cycle / engine ---
# How often (ms) market data is fed to models and positions are resolved.
CYCLE_INTERVAL_MS=300000

# --- Frontend ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
