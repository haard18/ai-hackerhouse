# ──────────────────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env.
# ──────────────────────────────────────────────────────────────

# --- Database (Postgres) ---
# Leave empty for local in-memory mode. Set for Neon/Postgres candle persistence.
DATABASE_URL=""

# --- API server ---
API_PORT=4000

# --- Model providers (Yug) — only set the ones you use ---
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_SITE_URL="http://localhost:4000"
OPENROUTER_APP_NAME="AI Trading Arena"
OPENROUTER_TIMEOUT_MS=60000
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL_ID="gpt-5.5"
OPENAI_REASONING_EFFORT="low"
OPENAI_TIMEOUT_MS=60000
GOOGLE_API_KEY=""

# --- Market data feed (data-feed package) ---
# Source: "stub" (deterministic fake, offline) or "binance" (live REST klines).
MARKET_DATA_SOURCE="stub"
# Binance REST base. Use https://api.binance.us in geo-blocked regions (e.g. US).
MARKET_DATA_BASE_URL="https://api.binance.com"
# Binance WebSocket base (live stream). Use wss://stream.binance.us:9443 for US.
MARKET_DATA_WS_BASE="wss://stream.binance.com:9443"
# Unused for public klines; reserved for authenticated/private feeds.
MARKET_DATA_API_KEY=""
MARKET_DATA_TIMEOUT_MS=10000
BINANCE_API_BASE="https://api.binance.com"

# --- Cycle / engine ---
# How often (ms) market data is fed to models and positions are resolved.
CYCLE_INTERVAL_MS=300000

# --- Frontend ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
