# ── API image: Express engine + cycle runner + ingestion ───────────────────
# Multi-stage pnpm-monorepo build. openssl/ca-certificates are required by the
# Prisma query engine at runtime.

FROM node:22-slim AS builder
RUN apt-get update \
  && apt-get install -y --no-install-recommends openssl ca-certificates \
  && rm -rf /var/lib/apt/lists/*
RUN corepack enable
WORKDIR /app

# Copy the whole workspace (host node_modules/.env excluded via .dockerignore)
COPY . .

# Install all workspace deps (apps/api postinstall runs `prisma generate`).
RUN pnpm install --frozen-lockfile
# Build the API and only the workspace packages it depends on.
RUN pnpm --filter "@ai-trading/api..." build

# ── runtime ─────────────────────────────────────────────────────────────────
FROM node:22-slim AS runner
RUN apt-get update \
  && apt-get install -y --no-install-recommends openssl ca-certificates \
  && rm -rf /var/lib/apt/lists/*
RUN corepack enable
ENV NODE_ENV=production
WORKDIR /app

COPY --from=builder /app /app

EXPOSE 4000
# Engine reads config from process.env (DATABASE_URL, OPENROUTER_API_KEY, ...).
CMD ["node", "apps/api/dist/index.js"]
