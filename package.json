{
  "name": "ai-trading",
  "version": "0.0.0",
  "private": true,
  "description": "AI model trading competition platform — models trade 5 assets on paper money, users stake on them.",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @ai-trading/api db:generate",
    "db:push": "pnpm --filter @ai-trading/api db:push"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "@types/node": "^20.14.0"
  }
}
