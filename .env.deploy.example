# Deployment env for docker-compose / Coolify. Copy to .env (compose) or set
# each as an environment variable in the Coolify UI. NEVER commit real secrets.

# --- Database (Neon Postgres) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/db?sslmode=require"

# --- Public URLs ---
# The API's public URL. The browser calls this directly; baked at web build time.
NEXT_PUBLIC_API_URL="https://api.your-domain.com"
# CORS allowlist for the API — comma-separated web origins. Empty = allow all.
ALLOWED_ORIGINS="https://your-domain.com"
# Host port mappings (Coolify usually assigns domains instead).
API_PORT=4000
WEB_PORT=3000

# --- Market data (live) ---
MARKET_DATA_SOURCE="binance"
MARKET_DATA_BASE_URL="https://api.binance.com"
MARKET_DATA_WS_BASE="wss://stream.binance.com:9443"
CYCLE_INTERVAL_MS=300000

# --- Model providers ---
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_SITE_URL="https://your-domain.com"
OPENROUTER_APP_NAME="AI Trading Arena"
OPENAI_API_KEY=""
OPENAI_MODEL_ID="gpt-5.5"
OPENAI_REASONING_EFFORT="medium"
